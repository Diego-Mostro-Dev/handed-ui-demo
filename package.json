{
  "name": "handed-ui",
  "version": "0.0.2",
  "description": "React UI components that adapt layout based on user's dominant hand",
  "author": "Diego A. Salvado",
  "homepage": "https://github.com/Diego-Mostro-Dev/handed-ui",
  "bugs": {
    "url": "https://github.com/Diego-Mostro-Dev/handed-ui/issues"
  },
  "sideEffects": false,
  "type": "module",
  "license": "MIT",
  "main": "./dist/handed-ui.cjs.js",
  "module": "./dist/handed-ui.es.js",
  "exports": {
    ".": {
      "import": "./dist/handed-ui.es.js",
      "require": "./dist/handed-ui.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode lib",
    "build:demo": "vite build",
    "preview": "vite preview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Diego-Mostro-Dev/handed-ui-demo.git"
  },
  "keywords": [
    "react",
    "react-ui",
    "hooks",
    "left-handed",
    "right-handed",
    "accessibility"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.0"
  }
}
